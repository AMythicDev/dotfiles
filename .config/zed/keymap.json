// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Editor && VimControl",
    "bindings": {
      "space s": "workspace::Save",
      "space l f": "editor::Format",
      "space l d": "editor::GoToDefinition",
      "space l r": "editor::Rename",
      "space space": "file_finder::Toggle",
      "space ]": "pane::ActivateNextItem",
      "space [": "pane::ActivatePreviousItem",
      "space /": "vim::ToggleComments",
      "space t": "workspace::ToggleBottomDock",
      "space q": "pane::CloseActiveItem",
    }
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "shift-y": "vim::YankToEndOfLine",
    }
  },
  {
    "context": "VimControl || Dock",
    "bindings": {
      "space l": "workspace::ToggleRightDock",
    }
  },
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "space e": "workspace::ToggleLeftDock",
      "a": "project_panel::NewFile",
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": ["workspace::SendKeystrokes", "escape"],
      "ctrl-h": "vim::Left",
      "ctrl-j": "vim::Down",
      "ctrl-k": "vim::Up",
      "ctrl-l": "vim::Right"
    }
  }
]
